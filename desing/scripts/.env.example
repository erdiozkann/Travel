# Foursquare → Supabase Seed Script Environment Variables
# Copy this file to .env and fill in your values

# 1. Foursquare API Key (get from https://developer.foursquare.com)
#    - Create account → Create App → Get API Key (Bearer token format)
#    - Free tier: 16,500 calls/day (enough for 12 cities x 10 categories x 20 results)
FOURSQUARE_API_KEY=Bearer YOUR_FOURSQUARE_API_KEY_HERE

# 2. Supabase Project URL
SUPABASE_URL=https://jhpvyyhqxilvnqwlqccb.supabase.co

# 3. Supabase SERVICE ROLE key (NOT anon key — needs write access to bypass RLS)
#    Get from: Supabase Dashboard → Settings → API → Service Role Key
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
